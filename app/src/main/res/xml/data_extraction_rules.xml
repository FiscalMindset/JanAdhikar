<?xml version="1.0" encoding="utf-8"?>
<!-- Nothing on this device is cloud-backed. Transcripts and SOS contacts
     never leave the handset — not even via Google backup transport. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
